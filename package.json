{
  "private": true,
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "repository": "https://github.com/comunica/comunica-feature-next/",
  "workspaces": [
    "engines/*",
    "packages/*",
    "performance/*"
  ],
  "scripts": {
    "build": "npm run build:ts && npm run build:components",
    "build:browser": "lerna run browser",
    "build:ts": "tsc",
    "build:components": "componentsjs-generator engines/* packages/*",
    "build-changed": "lerna run build --since HEAD",
    "build-watch": "nodemon -e ts --ignore '*.d.ts' --exec yarn run build",
    "build-watch:ts": "tsc --watch",
    "build-watch:components": "nodemon -e d.ts --exec yarn run build:components",
    "clean": "rm -rf ./node_modules && rm -rf ./packages/*/node_modules",
    "depcheck": "depcheckTask @comunica/config-query-sparql-next",
    "doc": "node_modules/@comunica/utils-monorepo/sh/typedoc-json.sh create && typedoc && node_modules/@comunica/utils-monorepo/sh/typedoc-json.sh remove",
    "lint": "eslint . --cache",
    "ncu:all": "lerna-script updateTask",
    "ncu:major:all": "lerna-script updateTaskMajor",
    "postinstall": "yarn run build && lerna run prepare",
    "publish": "yarn run build",
    "publish-release": "lerna publish",
    "publish-bare": "lerna exec -- npm publish --silent",
    "publish-canary": "yarn run build && lerna version prerelease --preid alpha.$(node_modules/@comunica/utils-monorepo/sh/get-next-alpha-version.sh @comunica/query-sparql-next) --exact --ignore-scripts --force-publish --no-push --no-git-tag-version --yes && git update-index --assume-unchanged $(git ls-files | tr '\\n' ' ') && lerna publish from-package --no-git-reset --pre-dist-tag next --force-publish --no-push --no-git-tag-version --yes && git update-index --no-assume-unchanged $(git ls-files | tr '\\n' ' ') && git checkout .",
    "test": "yarn run test:node",
    "test:browser": "playwright test",
    "test:docker": "lerna run test:docker --concurrency 1",
    "test:integration": "lerna run integration --concurrency 1",
    "test:node": "jest",
    "test:spec": "lerna run spec --concurrency 1",
    "test-changed": "lerna run test --since HEAD",
    "test-ci": "jest --ci --maxWorkers=4 --coverage",
    "version": "manual-git-changelog onversion"
  },
  "devDependencies": {
    "@comunica/packager": "^5.0.0",
    "@comunica/utils-jest": "^5.2.3",
    "@comunica/utils-monorepo": "^5.2.1",
    "@playwright/test": "^1.58.2",
    "@pollyjs/persister-fs": "^6.0.5",
    "@rubensworks/eslint-config": "^3.0.0",
    "@rubensworks/process-sparql-benchmark-results": "^1.3.4",
    "@types/benchmark": "^2.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.0",
    "@types/object-inspect": "^1.8.1",
    "@types/readable-stream": "^4.0.18",
    "@types/setup-polly-jest": "^0.5.2",
    "asynciterator": "^3.9.0",
    "benchmark": "^2.1.4",
    "componentsjs-generator": "^4.2.0",
    "eslint": "^8.57.0",
    "jest": "^30.0.0",
    "jest-mock": "^30.0.0",
    "jest-rdf": "^2.0.0",
    "lerna": "^9.0.0",
    "manual-git-changelog": "^1.0.2",
    "nodemon": "^3.0.0",
    "npm-check-updates": "^22.0.0",
    "pre-commit": "^1.2.2",
    "rdf-data-factory": "^2.0.2",
    "rdf-quad": "^2.0.0",
    "rdf-stores": "^2.1.1",
    "rdf-test-suite": "^2.1.5",
    "rdf-test-suite-ldf": "^2.0.1",
    "setup-polly-jest": "^0.11.0",
    "streamify-array": "^2.0.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.0.0",
    "typedoc": "^0.28.0",
    "typescript": "^6.0.0",
    "webpack": "^5.64.4",
    "webpack-bundle-analyzer": "^5.0.0",
    "webpack-cli": "^7.0.0"
  },
  "pre-commit": [
    "build",
    "lint",
    "test"
  ],
  "resolutions": {
    "rdf-parse": "5.0.0",
    "@traqula/chevrotain": "1.1.0",
    "@traqula/core": "1.1.4"
  }
}
