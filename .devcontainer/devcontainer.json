// See https://containers.dev/implementors/json_reference/ for configuration reference
{
  "name": "comunica-feature-next",
  "build": {
      "dockerfile": "Dockerfile"
  },
  "initializeCommand": "mkdir -p .devcontainer/.copilot .devcontainer/.claude",
  "mounts": [
    "source=${localWorkspaceFolder}/.devcontainer/.copilot,target=/home/node/.copilot/,type=bind",
    "source=${localWorkspaceFolder}/.devcontainer/.claude,target=/home/node/.claude/,type=bind"
  ],
  "remoteUser": "node",
  "customizations" : {
    "jetbrains" : {
      "backend" : "WebStorm"
    }
  }
}
